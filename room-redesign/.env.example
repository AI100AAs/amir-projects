# Copy this file to .env if you want to override defaults.

# Default Bonsai Image model from:
# https://huggingface.co/collections/prism-ml/bonsai-image
ROOM_MODEL_ID=prism-ml/bonsai-image-binary-4B-mlx-1bit

ROOM_BACKEND=bonsai-mlx
ROOM_MLX_MODEL_DIR=models/bonsai-image-4B-binary-mlx
ROOM_MLX_VAE=full
ROOM_MLX_DENSE_FALLBACK=0
ROOM_MLX_EVICT_TRANSFORMER=1
ROOM_MLX_LAZY_COMPONENTS=1
ROOM_FULL_FALLBACK_MODEL_ID=black-forest-labs/FLUX.2-klein-4B
ROOM_DEVICE=auto
ROOM_IMAGE_SIZE=512
ROOM_STEPS=4
ROOM_GUIDANCE=1.0
ROOM_IMAGE_STRENGTH=0.55
ROOM_TORCH_DTYPE=bfloat16
ROOM_LOCAL_FILES_ONLY=0
ROOM_LMSTUDIO_ENABLED=1
ROOM_PROMPT_HELPER_DEFAULT=0
ROOM_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
ROOM_LMSTUDIO_MODEL=google/gemma-4-e2b-qat
ROOM_LMSTUDIO_TIMEOUT=45
ROOM_LMSTUDIO_MAX_TOKENS=700
ROOM_MAX_UPLOAD_MB=24
ROOM_HISTORY_ITEMS=12
